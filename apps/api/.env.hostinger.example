# =============================================================================
# Hostinger Docker – API environment variables
# =============================================================================
# Set these in Hostinger Docker Manager (or in your compose/env file).
# Do NOT commit real values; use Hostinger's "Environment variables" UI.
# =============================================================================

# --- Required for API to run ---
NODE_ENV=production
PORT=3001

# --- Required for database ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# --- Required for chat (Stream) ---
STREAM_API_KEY=
STREAM_API_SECRET=

# --- Required for auth (use a long random secret in production) ---
JWT_SECRET=

# --- Required for CORS (your frontend URL) ---
WEB_APP_URL=https://aiplatform.gepanda.com/

# --- Optional: API base URL (used for server-side calls to this API) ---
API_URL=https://api.your-domain.com

# --- Optional: Activity Feeds (defaults to Stream Chat key/secret if unset) ---
# STREAM_FEEDS_API_KEY=
# STREAM_FEEDS_API_SECRET=

# --- Optional: AI (Zhipu) ---
# ZHIPU_API_KEY=

# --- Optional: Checkout / travel ---
# RYE_API_KEY=
# RYE_API_URL=https://api.rye.com
# CROSSMINT_API_KEY=
# CROSSMINT_PROJECT_ID=
# CROSSMINT_ENV=production

# --- Optional: Product search / shopping ---
# SERPAPI_API_KEY=
# DOBA_PUBLIC_KEY=
# DOBA_PRIVATE_KEY=
# GOOGLE_SHOPPING_COUNTRY=US
# GOOGLE_SHOPPING_LANGUAGE=en
# GOOGLE_SHOPPING_LOCATION=United States

# --- Optional: Travel ---
# TRAVELPAYOUTS_TOKEN=  (or TRAVELPAYOUTS_API_KEY)
# TRAVELPAYOUTS_MARKER=
# TRAVELPAYOUTS_BASE_URL=https://api.travelpayouts.com

# --- Optional: Other ---
# WEATHER_API_KEY=
# WEATHER_API_PROVIDER=openweathermap
# ADMIN_EMAILS=admin@example.com,other@example.com
# WEB_URL=https://your-domain.com
# FEED_INGESTION_INTERVAL_MINUTES=45
# FEED_INGESTION_RUN_ON_STARTUP=true
# ALLOW_INTERESTS_SEED=false
# ALLOW_FEED_SEED=false
# PRD_STRICT_MODE=true
# ENABLE_CALLS=true
# ENABLE_INVITES=true
# ENABLE_GROUP_CHANNELS=true
# ENABLE_HUMAN_MESSAGING=true

# --- Optional: Speech (if using voice) ---
# SPEECH_TO_TEXT_API=zhipu
# GOOGLE_SPEECH_API_KEY=
# WHISPER_API_KEY=
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
