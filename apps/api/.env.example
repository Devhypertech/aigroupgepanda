# Copy to .env and fill in values. Required for chat: STREAM_API_KEY, STREAM_API_SECRET.

# === Required for chat ===
STREAM_API_KEY=
STREAM_API_SECRET=

# === Optional: AI (Zhipu) ===
ZHIPU_API_KEY=

# === Optional: Database ===
DATABASE_URL=

# === Optional: Auth ===
JWT_SECRET=

# === Optional: Server ===
PORT=3001
NODE_ENV=development
WEB_APP_URL=http://localhost:3000

# === Optional: Activity Feeds (defaults to Stream Chat key/secret) ===
# STREAM_FEEDS_API_KEY=
# STREAM_FEEDS_API_SECRET=

# === Optional: Other services ===
# RYE_API_KEY=
# TRAVELPAYOUTS_API_KEY=
# WEATHER_API_KEY=
# DOBA_PUBLIC_KEY=
# DOBA_PRIVATE_KEY=
# ADMIN_EMAILS=

# === Optional: Crossmint (checkout link creation) ===
CROSSMINT_API_KEY=
CROSSMINT_PROJECT_ID=
CROSSMINT_ENV=sandbox

# === Optional: SerpAPI (Google shopping searches) ===
SERPAPI_API_KEY=

# === Optional: Google Shopping Configuration ===
GOOGLE_SHOPPING_COUNTRY=US
GOOGLE_SHOPPING_LANGUAGE=en
GOOGLE_SHOPPING_LOCATION=United States
