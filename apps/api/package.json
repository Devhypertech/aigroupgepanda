{
  "name": "@gepanda/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"console.log('✅ API build complete: dist/index.js')\"",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@gepanda/shared": "0.1.0",
    "@paralleldrive/cuid2": "^3.0.6",
    "@prisma/client": "^5.7.1",
    "@types/react-window": "^1.8.8",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "getstream": "^8.8.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "react-window": "^2.2.7",
    "rss-parser": "^3.13.0",
    "stream-chat": "^9.27.2",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prisma": "^5.7.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
